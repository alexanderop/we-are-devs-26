{
  "name": "alexop-slidev-stack",
  "version": "1.0.0",
  "description": "Reusable Slidev theme, addon, and starter template by @alexop",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter slidev-starter dev",
    "build": "pnpm --filter slidev-starter build",
    "export": "pnpm --filter slidev-starter export"
  },
  "keywords": [
    "slidev",
    "theme",
    "addon",
    "template"
  ],
  "author": "Alexander Opalic",
  "license": "MIT",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "overrides": {
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0 <5",
      "vite": ">=7.3.5 <8",
      "esbuild@>=0.27.3 <0.28.1": ">=0.28.1 <0.29",
      "postcss@<8.5.10": ">=8.5.10 <9",
      "picomatch@<2.3.2": ">=2.3.2 <3",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4 <5",
      "js-yaml": ">=4.2.0 <5",
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3 <3",
      "markdown-it@>=13.0.0 <14.2.0": ">=14.2.0 <15",
      "unhead@<2.1.13": ">=2.1.13 <3",
      "dompurify@<3.4.11": ">=3.4.11 <4",
      "lodash-es@<=4.17.23": ">=4.18.0 <5",
      "defu@<=6.1.4": ">=6.1.5 <7",
      "uuid@>=11.0.0 <11.1.1": ">=11.1.1 <12",
      "mermaid@>=11.0.0-alpha.1 <=11.14.0": ">=11.15.0 <12",
      "@babel/core@<=7.29.0": ">=7.29.6 <8"
    },
    "patchedDependencies": {
      "gray-matter@4.0.3": "patches/gray-matter@4.0.3.patch"
    }
  }
}
